<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="@color/md_theme_background"
    tools:context=".ui.HomeFragment">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/avatar"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:src="@drawable/dog"
        android:scaleType="centerCrop"
        android:contentDescription="@string/desc_avatar_usuario"
        app:shapeAppearance="@style/circleImageView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/hello_title"
        style="@style/TextAppearance.MaterialComponents.Headline4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:text="@string/ola_usuario"
        android:textColor="@color/text_primary"
        app:layout_constraintTop_toBottomOf="@+id/avatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/hello_subtitle"
        style="@style/TextAppearance.MaterialComponents.Subtitle1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/pergunta_dia_estudos"
        android:textColor="@color/text_secondary"
        app:layout_constraintTop_toBottomOf="@id/hello_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_community"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="@color/card_community_bg"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardCornerRadius="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hello_subtitle">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:layout_marginStart="30dp"
                android:text="@string/community"
                android:textFontWeight="500"
                android:textSize="24sp"
                android:textColor="@color/card_community_text"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginEnd="45dp"
                android:src="@drawable/ic_users_group"
                android:contentDescription="@string/desc_ilustracao_comunidade"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_achievements"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        app:cardBackgroundColor="@color/card_achievements_bg"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintHorizontal_weight="10"
        app:layout_constraintTop_toBottomOf="@id/card_community"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/card_checkin">

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.imageview.ShapeableImageView
        app:layout_constraintStart_toStartOf="@+id/card_achievements"
        app:layout_constraintTop_toTopOf="@id/card_achievements"
        android:layout_margin="14dp"

        android:layout_width="40dp"
        android:layout_height="40dp"

        app:shapeAppearance="@style/circleImageView"
       android:background="@color/card_achievements_icon_bg"
        app:contentPadding="6dp"
        android:src="@drawable/ic_star"/>

    <TextView
        app:layout_constraintBottom_toBottomOf="@id/card_achievements"
        app:layout_constraintStart_toStartOf="@id/card_achievements"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_marginStart="14dp"
        android:layout_marginBottom="10dp"

        android:textSize="20sp"
        android:textColor="@color/card_achievements_text"
        android:text="@string/achievements"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_checkin"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        app:cardBackgroundColor="@color/card_checkin_bg"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintHorizontal_weight="8"
        app:layout_constraintTop_toBottomOf="@id/card_community"
        app:layout_constraintStart_toEndOf="@id/card_achievements"
        app:layout_constraintEnd_toStartOf="@id/card_session">

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.imageview.ShapeableImageView
        app:layout_constraintStart_toStartOf="@+id/card_checkin"
        app:layout_constraintTop_toTopOf="@id/card_checkin"
        android:layout_margin="14dp"

        android:layout_width="40dp"
        android:layout_height="40dp"

        app:shapeAppearance="@style/circleImageView"
        android:background="@color/card_checkin_icon_bg"
        app:contentPadding="6dp"
        android:src="@drawable/ic_check"/>

    <TextView
        app:layout_constraintBottom_toBottomOf="@id/card_checkin"
        app:layout_constraintStart_toStartOf="@id/card_checkin"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_marginStart="14dp"
        android:layout_marginBottom="10dp"

        android:textSize="20sp"
        android:textColor="@color/card_checkin_text"
        android:text="@string/check_in"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_session"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_marginTop="10dp"
        app:cardBackgroundColor="@color/card_session_bg"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintHorizontal_weight="7"
        app:layout_constraintTop_toBottomOf="@id/card_community"
        app:layout_constraintStart_toEndOf="@id/card_checkin"
        app:layout_constraintEnd_toEndOf="parent">

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.imageview.ShapeableImageView
        app:layout_constraintStart_toStartOf="@+id/card_session"
        app:layout_constraintTop_toTopOf="@id/card_session"
        android:layout_margin="14dp"

        android:layout_width="40dp"
        android:layout_height="40dp"

        app:shapeAppearance="@style/circleImageView"
        android:background="@color/card_session_icon_bg"
        app:contentPadding="6dp"
        android:src="@drawable/clock"/>

    <TextView
        app:layout_constraintBottom_toBottomOf="@id/card_session"
        app:layout_constraintStart_toStartOf="@id/card_session"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_marginStart="14dp"
        android:layout_marginBottom="10dp"

        android:textSize="20sp"
        android:textColor="@color/card_session_text"
        android:text="@string/sessao"/>

    <View
        android:id="@+id/recommendation_view"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_marginTop="26dp"
        android:background="@drawable/bg_container"
        app:layout_constraintTop_toBottomOf="@id/card_achievements"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/recommendation_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        app:cardBackgroundColor="@color/md_theme_primary"
        app:cardElevation="0dp"
        app:cardCornerRadius="10dp"
        app:layout_constraintStart_toStartOf="@id/recommendation_view"
        app:layout_constraintTop_toTopOf="@id/recommendation_view"
        app:layout_constraintBottom_toTopOf="@id/recommendation_view">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recommendation"
            android:textFontWeight="800"
            android:textColor="@color/text_light"
            android:layout_marginHorizontal="14dp"
            android:layout_marginVertical="2dp" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/recommendation_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="12dp"
        android:textSize="18sp"
        android:textColor="@color/text_primary"
        android:text="História - Revolução Francesa"
        app:layout_constraintTop_toBottomOf="@id/recommendation_badge"
        app:layout_constraintStart_toStartOf="@id/recommendation_view"
        app:layout_constraintEnd_toEndOf="@id/recommendation_view" />

    <TextView
        android:id="@+id/recommendation_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="4dp"
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:text="Sua prova é em 3 dias. Dedique 2 horas hoje."
        app:layout_constraintTop_toBottomOf="@+id/recommendation_title"
        app:layout_constraintStart_toStartOf="@id/recommendation_view"
        app:layout_constraintEnd_toEndOf="@id/recommendation_view" />

</androidx.constraintlayout.widget.ConstraintLayout>