<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.HomeFragment"
    android:padding="20dp"
    android:background="@color/white">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/avatar"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"

        android:src="@drawable/dog"

        app:shapeAppearance="@style/circleImageView"
        android:layout_width="45dp"
        android:layout_height="45dp"

        android:scaleType="centerCrop"
        />

    <TextView
        android:id="@+id/hello_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        style="@style/TextAppearance.MaterialComponents.Headline4"
        android:textStyle="bold"
        android:text="Olá João"
        android:textColor="@color/text_primary"
        app:layout_constraintTop_toBottomOf="@+id/avatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <TextView
        android:id="@+id/hello_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/hello_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="Como foi seu dia de estudos hoje?"
        style="@style/TextAppearance.MaterialComponents.Subtitle1"
        android:textColor="@color/text_secondary"
        />



    <com.google.android.material.card.MaterialCardView
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hello_subtitle"
        android:id="@+id/card_community"

        android:layout_width="0dp"
        android:layout_height="140dp"
        android:layout_marginTop="32dp"

        app:cardBackgroundColor="@color/card_community_bg"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardCornerRadius="20dp"
       >
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
        <TextView
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Comunidades"
            android:textFontWeight="500"
            style="@style/TextAppearance.MaterialComponents.Headline5"
            android:textColor="@color/card_community_text"
            android:layout_marginBottom="20dp"
            android:layout_marginStart="30dp"
            />
        <ImageView
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginEnd="45dp"
            android:src="@drawable/ic_users_group"
            />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_community"
        android:orientation="horizontal"
        android:weightSum="3"
        android:baselineAligned="false"
        android:layout_marginTop="10dp"
        >
        
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/card_achievements_bg"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:layout_marginEnd="10dp"

            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="20dp"
                >

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@color/card_achievements_icon_bg"
                    android:src="@drawable/ic_star"
                    android:layout_gravity="left"
                    app:shapeAppearance="@style/circleImageView"

                    />


            </LinearLayout>

        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/card_checkin_bg"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:layout_marginEnd="10dp"
            >



        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/card_session_bg"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            >

        </androidx.cardview.widget.CardView>

        
    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>